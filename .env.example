# OpenClaw Railway Template - Environment Variables
# Copy this file to .env for local development

# ==============================================================================
# REQUIRED CONFIGURATION
# ==============================================================================

# Setup wizard password - protects the /onboard endpoint
# Generate with: openssl rand -hex 24
SETUP_PASSWORD=your-secure-password-here

# ==============================================================================
# DATA PERSISTENCE (Recommended)
# ==============================================================================

# State directory for OpenClaw configuration, sessions, credentials
# On Railway, this should be within your mounted volume at /data
OPENCLAW_STATE_DIR=/data/.openclaw

# Workspace directory for file storage
OPENCLAW_WORKSPACE_DIR=/data/workspace

# ==============================================================================
# OPTIONAL CONFIGURATION
# ==============================================================================

# Gateway authentication token
# If not set, the wrapper server will auto-generate one and store it
# in $OPENCLAW_STATE_DIR/gateway.token
# OPENCLAW_GATEWAY_TOKEN=your-gateway-token

# Internal gateway port (default: 18789)
# This is the port OpenClaw gateway listens on internally
# INTERNAL_GATEWAY_PORT=18789

# ==============================================================================
# OPERATOR TOOLING AUTH (Optional)
# ==============================================================================

# GitHub CLI (`gh`) — non-interactive auth token.
# If set, `gh` will use it automatically (same behaviour as `gh auth login --with-token`).
# Scope to the minimum needed (e.g. `repo`, `read:org`).
# GH_TOKEN=ghp_...

# Railway CLI (`railway`) — non-interactive auth token.
# Generate at https://railway.app/account/tokens (account-level) or use a
# project-scoped token. When set, `railway` skips the browser login flow.
# RAILWAY_TOKEN=...

# ==============================================================================
# BROWSER AUTOMATION
# ==============================================================================

# Chromium is pre-installed for browser automation (web scraping, screenshots, etc.)
# Override the browser binary path if needed:
# PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

# ==============================================================================
# LOCAL DEVELOPMENT ONLY
# ==============================================================================

# Port for local development (Railway sets this automatically)
# PORT=8080
